---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  includeFaqSchema?: boolean;
}

const {
  title,
  description = 'San Luis Obispo and SLO County electrician. EV chargers, panel upgrades, lighting, new builds. Licensed, insured, owner-operated. Free estimates.',
  canonical = 'https://keifelectric.com/',
  includeFaqSchema = true,
} = Astro.props;

import '../../styles/global.css';
import { siteContent } from '../../content/site';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: siteContent.faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#242021" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Keif Electric" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://keifelectric.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://keifelectric.com/og-image.png" />

    <!-- Geo + business meta -->
    <meta name="geo.region" content="US-CA" />
    <meta name="geo.placename" content="San Luis Obispo" />
    <meta name="geo.position" content="35.2828;-120.6596" />
    <meta name="ICBM" content="35.2828, -120.6596" />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Schema markup -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": ["LocalBusiness", "Electrician"],
        "name": "Keif Electric",
        "description": "Licensed electrician serving San Luis Obispo and SLO County. EV chargers, panel upgrades, lighting, new builds. Owner-operated by Adam Keif.",
        "hasCredential": "CA# 1152084",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "San Luis Obispo",
          "addressRegion": "CA",
          "postalCode": "93401",
          "addressCountry": "US"
        },
        "telephone": "+18052860477",
        "email": "adam@keifelectric.com",
        "openingHours": "Mo-Fr 09:00-17:00",
        "priceRange": "$$",
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "35.2828",
          "longitude": "-120.6596"
        },
        "areaServed": [
          "San Luis Obispo", "Atascadero", "Paso Robles", "Templeton",
          "Santa Margarita", "Arroyo Grande", "Santa Maria",
          "Morro Bay", "Los Osos", "Cayucos", "Cambria", "Pismo Beach"
        ],
        "employee": {
          "@type": "Person",
          "name": "Adam Keif",
          "jobTitle": "Owner, Licensed Electrician",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "San Luis Obispo",
            "addressRegion": "CA",
            "addressCountry": "US"
          }
        }
      }
    </script>

    <!-- FAQPage schema (homepage only) -->
    {includeFaqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

    <slot name="head" />

    <!-- Meta Pixel placeholder (uncomment on launch) -->
    <!-- <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=XXXXXXXXXXXXX&ev=PageView&noscript=1" /> -->

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-46WM4RFWW4"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-46WM4RFWW4');

      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href^="tel:"]');
        if (!link) return;
        gtag('event', 'phone_click', {
          event_category: 'contact',
          event_label: link.closest('section')?.id || 'header'
        });
      });
    </script>
  </head>
  <body>
    <slot />

    <div class="call-bar" role="region" aria-label="Quick contact">
      <a class="call-bar__call" href="tel:+18052860477">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        Call (805) 286-0477
      </a>
      <a class="call-bar__quote" href="#contact">Quote</a>
    </div>
  </body>
</html>

<style>
  .call-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40;
    display: none;
    gap: 8px;
    padding: 10px 14px calc(10px + env(safe-area-inset-bottom, 0px));
    background: var(--ke-ink);
    border-top: 1px solid rgba(246, 241, 232, 0.12);
    box-shadow: 0 -8px 24px -12px rgba(26, 23, 24, 0.5);
  }

  .call-bar__call {
    flex: 1 1 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 52px;
    padding: 0 16px;
    background: var(--ke-orange);
    color: #fff;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 16px;
    border-radius: var(--radius-3);
    text-decoration: none;
  }

  .call-bar__call:active {
    transform: translateY(1px);
  }

  .call-bar__call svg {
    width: 18px;
    height: 18px;
    flex: none;
  }

  .call-bar__quote {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 20px;
    color: var(--ke-bone);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 15px;
    border: 1px solid rgba(246, 241, 232, 0.38);
    border-radius: var(--radius-3);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .call-bar {
      display: flex;
    }
  }
</style>

