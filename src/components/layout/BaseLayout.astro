---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'San Luis Obispo and SLO County electrician. EV chargers, panel upgrades, lighting, new builds. Licensed, insured, owner-operated. Free estimates.' } = Astro.props;

import '../../styles/global.css';
import { siteContent } from '../../content/site';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: siteContent.faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#242021" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://keifelectric.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Keif Electric" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://keifelectric.com/" />
    <meta property="og:image" content="https://keifelectric.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://keifelectric.com/og-image.png" />

    <!-- Geo + business meta -->
    <meta name="geo.region" content="US-CA" />
    <meta name="geo.placename" content="San Luis Obispo" />
    <meta name="geo.position" content="35.2828;-120.6596" />
    <meta name="ICBM" content="35.2828, -120.6596" />

    <!-- Preload above-fold fonts -->
    <link rel="preload" href="/fonts/ClimateCrisis-2050.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/Geist-Medium.ttf" as="font" type="font/truetype" crossorigin>
    <link rel="preload" href="/fonts/Geist-Bold.ttf" as="font" type="font/truetype" crossorigin>

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Schema markup -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": ["LocalBusiness", "Electrician"],
        "name": "Keif Electric",
        "description": "Licensed electrician serving San Luis Obispo and SLO County. EV chargers, panel upgrades, lighting, new builds. Owner-operated by Adam Keif.",
        "hasCredential": "CA# 1152084",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "San Luis Obispo",
          "addressRegion": "CA",
          "postalCode": "93401",
          "addressCountry": "US"
        },
        "telephone": "+18052860477",
        "email": "adam@keifelectric.com",
        "openingHours": "Mo-Fr 09:00-17:00",
        "priceRange": "$$",
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "35.2828",
          "longitude": "-120.6596"
        },
        "areaServed": [
          "San Luis Obispo", "Atascadero", "Paso Robles", "Templeton",
          "Santa Margarita", "Arroyo Grande", "Santa Maria",
          "Morro Bay", "Los Osos", "Cayucos", "Cambria", "Pismo Beach"
        ],
        "employee": {
          "@type": "Person",
          "name": "Adam Keif",
          "jobTitle": "Owner, Licensed Electrician",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "San Luis Obispo",
            "addressRegion": "CA",
            "addressCountry": "US"
          }
        }
      }
    </script>

    <!-- FAQPage schema -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <!-- GA4 placeholder (uncomment on launch) -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script> -->

    <!-- Meta Pixel placeholder (uncomment on launch) -->
    <!-- <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=XXXXXXXXXXXXX&ev=PageView&noscript=1" /> -->
  </head>
  <body>
    <slot />
  </body>
</html>

