---
import { siteContent } from '../../content/site';
---

<header class="site-header" role="banner">
  <div class="site-header__inner">
    <a href="#top" class="brand-lockup" aria-label="Keif Electric, home">
      <img
        src="/assets/logos/logo-primary.svg"
        alt="Keif Electric"
        class="brand-lockup__mark"
      />
    </a>

    <nav class="site-nav" id="site-nav" aria-label="Main navigation">
      {siteContent.nav.map(item => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="site-header__cta">
      <a href={`tel:+18052860477`} class="header-tel">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z" />
        </svg>
        {siteContent.phone}
      </a>
      <a href="#contact" class="header-cta-btn">Get a quote</a>
    </div>

    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav class="mobile-menu__nav" aria-label="Mobile navigation">
    {siteContent.nav.map(item => (
      <a href={item.href} class="mobile-menu__link">{item.label}</a>
    ))}
  </nav>
  <div class="mobile-menu__ctas">
    <a href="tel:+18052860477" class="btn btn--primary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
      Call (805) 286-0477
    </a>
    <a href="#contact" class="btn btn--outline">Get a free quote</a>
  </div>
</div>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    if (!isOpen) {
      menu?.removeAttribute('aria-hidden');
    } else {
      menu?.setAttribute('aria-hidden', 'true');
    }
    toggle.classList.toggle('is-open', !isOpen);
    menu?.classList.toggle('is-open', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      toggle?.classList.remove('is-open');
      menu.classList.remove('is-open');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: var(--ke-ink);
    color: var(--ke-bone);
    border-bottom: 1px solid rgba(246, 241, 232, 0.06);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 32px;
    height: var(--header-h);
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .brand-lockup {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    text-decoration: none;
  }

  .brand-lockup__mark {
    height: 42px;
    width: auto;
  }

  .site-nav {
    display: flex;
    gap: 28px;
    justify-content: center;
  }

  .site-nav a {
    color: rgba(246, 241, 232, 0.78);
    font-weight: 500;
    font-size: 14px;
    padding: 6px 0;
    border-bottom: 2px solid transparent;
    transition: color var(--dur-1) var(--ease-out), border-color var(--dur-1) var(--ease-out);
  }

  .site-nav a:hover {
    color: var(--ke-bone);
    border-bottom-color: var(--ke-orange);
  }

  .site-header__cta {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .header-tel {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ke-bone);
    font-weight: 600;
    font-size: 15px;
    padding: 8px 6px;
    transition: color var(--dur-1) var(--ease-out);
  }

  .header-tel svg {
    width: 16px;
    height: 16px;
    color: var(--ke-orange);
    transition: color var(--dur-1) var(--ease-out);
  }

  .header-tel:hover {
    color: var(--ke-orange);
  }

  .header-tel:hover svg {
    color: var(--ke-bone);
  }

  .header-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: var(--ke-orange);
    color: #fff;
    font-weight: 600;
    font-size: 14px;
    border-radius: var(--radius-2);
    text-decoration: none;
    transition: background var(--dur-1) var(--ease-out);
  }

  .header-cta-btn:hover {
    background: #E95B2D;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-right: -8px;
  }

  .nav-toggle__bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ke-bone);
    border-radius: 2px;
    transition: transform var(--dur-2) var(--ease-out), opacity var(--dur-1) var(--ease-out);
    transform-origin: center;
  }

  .nav-toggle.is-open .nav-toggle__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle.is-open .nav-toggle__bar:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle.is-open .nav-toggle__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    inset: var(--header-h) 0 0 0;
    background: var(--ke-ink);
    z-index: 50;
    flex-direction: column;
    padding: 32px 24px 40px;
    overflow-y: auto;
    transform: translateY(-8px);
    opacity: 0;
    transition: opacity var(--dur-2) var(--ease-out), transform var(--dur-2) var(--ease-out);
  }

  .mobile-menu.is-open {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .mobile-menu__link {
    font-size: 22px;
    font-weight: 700;
    color: var(--ke-bone);
    padding: 14px 0;
    border-bottom: 1px solid rgba(246, 241, 232, 0.08);
    letter-spacing: -0.01em;
    transition: color var(--dur-1) var(--ease-out);
  }

  .mobile-menu__link:hover {
    color: var(--ke-orange);
  }

  .mobile-menu__ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 32px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 16px 22px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 16px;
    border-radius: var(--radius-3);
    min-height: 54px;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background var(--dur-1) var(--ease-out), color var(--dur-1) var(--ease-out);
  }

  .btn svg {
    width: 18px;
    height: 18px;
    flex: none;
  }

  .btn--primary {
    background: var(--ke-orange);
    color: #fff;
  }

  .btn--primary:hover {
    background: #E95B2D;
  }

  .btn--outline {
    background: transparent;
    color: var(--ke-bone);
    border-color: rgba(246, 241, 232, 0.3);
  }

  .btn--outline:hover {
    border-color: var(--ke-bone);
  }

  @media (max-width: 768px) {
    .site-nav,
    .site-header__cta {
      display: none;
    }

    .site-header__inner {
      grid-template-columns: auto 1fr;
    }

    .nav-toggle {
      display: flex;
      justify-self: end;
    }

    .mobile-menu {
      display: flex;
    }
  }
</style>
