---
import { siteContent } from '../../content/site';
---

<section class="section" id="faq">
  <div class="container">
    <div class="faq__inner">
      <aside class="faq__sidebar">
        <span class="eyebrow">Frequently asked</span>
        <h2 class="section__title">Electrical Contractor FAQ</h2>
        <p>
          Common questions about licensing, pricing, permits, and how we work. Don't see yours?
          <a href="tel:+18052860477" style="color:var(--ke-orange); font-weight:600">(805) 286-0477</a>.
        </p>
        <a href="#contact" class="btn btn--outline">
          Still have a question? Ask us
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
      </aside>

      <div class="faq__list">
        {siteContent.faqs.map((faq, index) => (
          <details class="faq-item" open={index === 0}>
            <summary class="faq-item__btn">
              <span>{faq.question}</span>
              <span class="faq-item__icon" aria-hidden="true"></span>
            </summary>
            <div class="faq-item__answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 120px 0;
    background: var(--ke-bone);
  }

  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--gutter);
    padding-right: var(--gutter);
  }

  .faq__inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 64px;
    align-items: flex-start;
  }

  .faq__sidebar {
    position: sticky;
    top: 96px;
  }

  .faq__sidebar h2 {
    font-weight: 900;
    font-size: clamp(34px, 3.6vw, 48px);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .faq__sidebar p {
    font-size: 16px;
    color: var(--fg-2);
    margin: 18px 0 24px;
    max-width: 38ch;
  }

  .section__title {
    font-weight: 900;
    font-size: clamp(34px, 3.6vw, 48px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 14px 0 0;
    color: var(--ke-ink);
    max-width: 18ch;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ke-clay);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .eyebrow::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--ke-clay);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 13px 18px;
    font-weight: 600;
    font-size: 15px;
    border: 1px solid var(--ke-ink);
    background: transparent;
    color: var(--ke-ink);
    border-radius: var(--radius-2);
    text-decoration: none;
    cursor: pointer;
    transition: all var(--dur-1) var(--ease-out);
  }

  .btn:hover {
    background: var(--ke-ink);
    color: var(--ke-bone);
  }

  .btn svg {
    width: 18px;
    height: 18px;
  }

  .btn--outline {
    border-color: var(--ke-ink);
  }

  .faq__list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid var(--border-1);
    padding: 0;
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--border-1);
  }

  .faq-item__btn {
    width: 100%;
    text-align: left;
    background: transparent;
    border: 0;
    padding: 24px 8px;
    padding-right: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 700;
    color: var(--ke-ink);
    letter-spacing: -0.01em;
    line-height: 1.3;
    position: relative;
    transition: color var(--dur-1) var(--ease-out);
  }

  .faq-item__btn:hover {
    color: var(--ke-orange);
  }

  .faq-item__icon {
    flex: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--ke-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform var(--dur-2) var(--ease-out), background var(--dur-1) var(--ease-out), border-color var(--dur-1) var(--ease-out);
  }

  .faq-item__icon::before,
  .faq-item__icon::after {
    content: '';
    position: absolute;
    background: var(--ke-ink);
    transition: transform var(--dur-2) var(--ease-out), background var(--dur-1) var(--ease-out);
  }

  .faq-item__icon::before {
    width: 12px;
    height: 1.8px;
  }

  .faq-item__icon::after {
    width: 1.8px;
    height: 12px;
  }

  .faq-item[open] .faq-item__icon {
    background: var(--ke-orange);
    border-color: var(--ke-orange);
    transform: rotate(180deg);
  }

  .faq-item[open] .faq-item__icon::before,
  .faq-item[open] .faq-item__icon::after {
    background: #fff;
  }

  .faq-item[open] .faq-item__icon::after {
    transform: scaleY(0);
  }

  .faq-item__answer {
    padding: 0 8px 28px;
    max-width: 64ch;
    font-size: 16px;
    line-height: 1.6;
    color: var(--fg-2);
  }

  .faq-item__answer p {
    margin: 0 0 12px;
  }

  .faq-item__answer p:last-child {
    margin-bottom: 0;
  }

  .faq-item__answer strong {
    color: var(--ke-ink);
    font-weight: 700;
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  @media (max-width: 768px) {
    .faq__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .faq__sidebar {
      position: static;
    }

    .section {
      padding: 72px 0;
    }
  }
</style>
