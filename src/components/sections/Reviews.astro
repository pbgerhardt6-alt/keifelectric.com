---
import { siteContent } from '../../content/site';
---

<section class="section section--paper" id="reviews" aria-labelledby="reviews-title">
  <div class="section__head">
    <div>
      <span class="eyebrow">What homeowners say</span>
      <h2 id="reviews-title" class="section__title">Trusted by neighbors across the Central Coast.</h2>
    </div>
    <p class="section__lead">
      Real reviews from real homeowners on Google and Yelp. We treat every job like we'd want our own house treated.
    </p>
  </div>

  <div class="container">
    {siteContent.reviews.length > 0 && (
      <div class="reviews__grid">
        {siteContent.reviews.map((review) => (
          <article class="review-card">
            <div class="review-card__stars" aria-label={`${review.rating} out of 5 stars`}>
              {[...Array(5)].map(() => (
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
              ))}
            </div>
            <p class="review-card__body">{review.text}</p>
            <div class="review-card__foot">
              <div class={`review-card__avatar${review.avatarBg ? ' ' + review.avatarBg : ''}`}>{review.avatar}</div>
              <div>
                <p class="review-card__name">{review.name}</p>
                <p class="review-card__meta">{review.location} · {review.service}</p>
              </div>
              <span class="review-card__source">{review.source}</span>
            </div>
          </article>
        ))}
      </div>
    )}

    <div class="reviews__summary" role="note">
      <div class="reviews__summary-stars" aria-hidden="true">
        {[...Array(5)].map(() => (
          <svg viewBox="0 0 24 24" fill="currentColor">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        ))}
      </div>
      <strong>5.0 on Google &amp; Yelp</strong>
      <span>Read the reviews from Central Coast homeowners</span>
      <div class="reviews__summary-links">
        <a href={siteContent.reviewBadges.google.url} target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
          Google reviews
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
        </a>
        <a href={siteContent.reviewBadges.yelp.url} target="_blank" rel="noopener noreferrer" class="btn btn--ghost">
          Yelp reviews
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 120px 0;
    background: var(--ke-paper);
    border-top: 1px solid var(--border-1);
    border-bottom: 1px solid var(--border-1);
  }

  .section--paper {
    background: var(--ke-paper);
  }

  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--gutter);
    padding-right: var(--gutter);
  }

  .section__head {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: end;
    margin-bottom: 56px;
    max-width: var(--max);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--gutter);
    padding-right: var(--gutter);
  }

  .section__title {
    font-weight: 900;
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 14px 0 0;
    color: var(--ke-ink);
    max-width: 18ch;
  }

  .section__lead {
    font-size: 17px;
    line-height: 1.55;
    color: var(--fg-2);
    max-width: 48ch;
    margin: 0;
    font-weight: 500;
    align-self: end;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ke-clay);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .eyebrow::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--ke-clay);
  }

  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 36px;
  }

  .review-card {
    background: var(--ke-paper);
    border: 1px solid var(--border-1);
    border-radius: var(--radius-3);
    padding: 28px 26px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: box-shadow var(--dur-2) var(--ease-out), transform var(--dur-2) var(--ease-out);
  }

  .review-card:hover {
    box-shadow: var(--shadow-2);
  }

  .review-card__stars {
    display: flex;
    gap: 2px;
    color: var(--ke-orange);
  }

  .review-card__stars svg {
    width: 18px;
    height: 18px;
  }

  .review-card__body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ke-ink);
    margin: 0;
    flex: 1;
  }

  .review-card__foot {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--border-1);
  }

  .review-card__avatar {
    width: 42px;
    height: 42px;
    flex: none;
    background: var(--ke-clay);
    color: var(--ke-bone);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
  }

  .review-card__avatar.bg-amber {
    background: var(--ke-amber);
    color: var(--ke-ink);
  }

  .review-card__avatar.bg-orange {
    background: var(--ke-orange);
    color: #fff;
  }

  .review-card__name {
    font-size: 14px;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .review-card__meta {
    font-size: 12.5px;
    color: var(--fg-2);
    margin-top: 2px;
  }

  .review-card__source {
    margin-left: auto;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-2);
    background: var(--ke-bone);
    padding: 4px 8px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-1);
  }

  .reviews__summary {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    margin-top: 36px;
    padding: 18px 22px;
    background: var(--ke-paper);
    border: 1px solid var(--border-1);
    border-radius: var(--radius-3);
  }

  .reviews__summary-stars {
    display: flex;
    gap: 2px;
    color: var(--ke-orange);
  }

  .reviews__summary-stars svg {
    width: 18px;
    height: 18px;
  }

  .reviews__summary strong {
    font-size: 16px;
    color: var(--ke-ink);
    margin-right: 4px;
  }

  .reviews__summary span {
    font-size: 14px;
    color: var(--fg-3);
  }

  .reviews__summary-links {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    color: var(--fg-1);
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid var(--border-1);
    border-radius: var(--radius-2);
    transition: background var(--dur-1) var(--ease-out);
    background: transparent;
  }

  .btn:hover {
    background: rgba(36, 32, 33, 0.06);
  }

  .btn svg {
    width: 15px;
    height: 15px;
  }

  @media (max-width: 900px) {
    .reviews__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .section__head {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .section {
      padding: 72px 0;
    }

    .reviews__summary {
      flex-wrap: wrap;
    }

    .reviews__summary-links {
      margin-left: 0;
      margin-top: 12px;
      width: 100%;
    }

    .reviews__summary-links .btn {
      flex: 1;
      justify-content: center;
    }
  }
</style>
