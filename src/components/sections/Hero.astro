---
import { siteContent } from '../../content/site';
---

<section class="hero" aria-label="Licensed Electrician in San Luis Obispo, CA">
  <div class="hero__inner">
    <div class="hero__copy">
      <h1 class="eyebrow">Licensed Electrician in San Luis Obispo, CA</h1>
      <p id="hero-title" class="hero__title">
        <span class="hero__title-line">Wired right<span class="hero__title-period" aria-hidden="true"></span></span>
        <span class="hero__title-line hero__title-line--accent">the first time<span class="hero__title-period" aria-hidden="true"></span></span>
      </p>
      <p class="hero__lead">
        Licensed electrical contractor serving <strong>San Luis Obispo, Atascadero, Paso Robles, and SLO County</strong>.
        Panel upgrades, EV chargers, lighting, troubleshooting, new builds — permitted, inspected, and completed without surprises.
        Owner-operated by Adam Keif.
      </p>
      <div class="hero__ctas">
        <a class="btn btn--primary btn--lg" href="tel:+18052860477">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          Call (805) 286-0477
        </a>
        <a class="btn btn--outline btn--lg" href="#contact">
          Get a free quote
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="hero__trust">
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg> California C-10 licensed</span>
        <span class="dot" aria-hidden="true"></span>
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 18h20M5 18v-6a7 7 0 0 1 14 0v6M9 8V5a3 3 0 0 1 6 0v3"/></svg> Liability insured</span>
        <span class="dot" aria-hidden="true"></span>
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Free estimates</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--ke-bone);
    overflow: hidden;
    min-height: calc(100vh - var(--header-h));
    display: flex;
    flex-direction: column;
  }

  .hero__inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    max-width: var(--max);
    width: 100%;
    margin: 0 auto;
    padding: 52px var(--gutter) 44px;
  }

  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--gutter);
    padding-right: var(--gutter);
  }

  .hero__copy {
    max-width: 780px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ke-clay);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .eyebrow::before {
    content: none;
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(56px, 7.5vw, 124px);
    line-height: 0.88;
    letter-spacing: -0.005em;
    color: var(--ke-ink);
    margin: 14px 0 0;
    font-variation-settings: "YEAR" 2050;
  }

  .hero__title-line {
    display: block;
  }

  .hero__title-line--accent {
    color: var(--ke-orange);
    position: relative;
  }

  .hero__title-period {
    display: inline-block;
    width: 0.18em;
    height: 0.18em;
    background: var(--ke-orange);
    margin-bottom: 0.06em;
    margin-left: 0.04em;
    vertical-align: baseline;
    border-radius: 2px;
  }

  .hero__lead {
    font-size: 18px;
    line-height: 1.55;
    max-width: 54ch;
    color: var(--ke-ink);
    margin: 28px 0 24px;
    font-weight: 500;
  }

  .hero__lead strong {
    font-weight: 700;
  }

  .hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 0;
  }

  .btn {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 15px;
    padding: 13px 18px;
    border-radius: var(--radius-2);
    border: 1px solid transparent;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    line-height: 1;
    min-height: 48px;
    transition: background var(--dur-1) var(--ease-out), color var(--dur-1) var(--ease-out),
      transform var(--dur-1) var(--ease-out), box-shadow var(--dur-1) var(--ease-out),
      border-color var(--dur-1) var(--ease-out);
    text-decoration: none;
    white-space: nowrap;
  }

  .btn svg {
    width: 18px;
    height: 18px;
    flex: none;
  }

  .btn--primary {
    background: var(--ke-orange);
    color: #fff;
  }

  .btn--primary:hover {
    background: #E95B2D;
  }

  .btn--primary:active {
    transform: translateY(1px);
  }

  .btn--outline {
    background: transparent;
    color: var(--ke-ink);
    border-color: var(--ke-ink);
  }

  .btn--outline:hover {
    background: var(--ke-ink);
    color: var(--ke-bone);
  }

  .btn--lg {
    padding: 16px 22px;
    font-size: 16px;
    border-radius: var(--radius-3);
    min-height: 54px;
  }

  .hero__trust {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    color: var(--fg-2);
    font-size: 13px;
    font-weight: 600;
    align-items: center;
    margin-top: auto;
    padding-top: 32px;
  }

  .hero__trust span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  .hero__trust svg {
    width: 16px;
    height: 16px;
    color: var(--ke-clay);
    flex: none;
  }

  .dot {
    width: 3px;
    height: 3px;
    background: var(--ke-stone);
    border-radius: 50%;
    display: inline-block;
  }

  @media (max-width: 768px) {
    .eyebrow {
      white-space: normal;
      line-height: 1.4;
    }

    .hero__trust {
      margin-top: 20px;
      padding-top: 0;
    }
  }
</style>

