---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const title = 'New Construction & Remodel Electrical in San Luis Obispo County | Keif Electric';
const description = 'Full residential electrical for new builds, ADUs, and major remodels, rough-in to finish trim. Coordinated with your GC. Licensed, owner-operated by Adam Keif. Serving SLO County.';
const canonical = 'https://keifelectric.com/services/newbuild';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'New Construction & Remodel Electrical',
  description: 'Full residential electrical for new builds, ADUs, and major remodels. Rough-in, panel installation, dedicated circuits, finish trim. Permitted and inspected. Serving San Luis Obispo County.',
  provider: {
    '@type': 'Electrician',
    name: 'Keif Electric',
    telephone: '+18052860477',
    areaServed: 'San Luis Obispo County, CA',
  },
  areaServed: 'San Luis Obispo County, CA',
  serviceType: 'New Construction Electrical',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Do you work with general contractors on new builds?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes, that\'s most of this work. I handle the electrical scope and coordinate around the build schedule so I\'m not the trade that holds things up.' },
    },
    {
      '@type': 'Question',
      name: 'Do you do ADU electrical?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. Full electrical for accessory dwelling units, from panel and circuits through finish, permitted and inspected.' },
    },
    {
      '@type': 'Question',
      name: 'Can you handle both rough-in and finish?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes, the whole electrical scope: rough-in, panel, dedicated circuits, and finish trim.' },
    },
    {
      '@type': 'Question',
      name: 'Do you pull the electrical permits on a build?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. I pull the electrical permits and coordinate inspections around the project schedule.' },
    },
    {
      '@type': 'Question',
      name: 'What areas do you serve?',
      acceptedAnswer: { '@type': 'Answer', text: 'San Luis Obispo, Atascadero, Paso Robles, and surrounding SLO County.' },
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical} includeFaqSchema={false}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />

  <main id="main">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="container">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#services">Services</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">New Construction &amp; Remodels</span>
      </div>
    </nav>

    <section class="svc-hero" id="top" aria-labelledby="page-h1">
      <div class="svc-hero__inner container">
        <div class="svc-hero__copy">
          <p class="svc-hero__eyebrow">
            <svg class="svc-hero__spark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2 4.5 13.5H11l-1 8.5 8.5-11.5H12l1-8.5Z"/></svg>
            New Construction &amp; Remodels
          </p>
          <h1 id="page-h1" class="svc-hero__title">
            <span class="svc-hero__line">New construction</span>
            <span class="svc-hero__line svc-hero__line--accent">&amp; remodels<span class="svc-hero__dot" aria-hidden="true"></span></span>
            <span class="svc-hero__place">in San Luis Obispo County</span>
          </h1>
          <p class="svc-hero__sub">Full residential electrical for new builds, ADUs, and major remodels, rough-in to finish trim. Coordinated with your GC, permitted and inspected. Owner-operated by Adam Keif.</p>
          <div class="svc-hero__ctas">
            <a class="btn btn--primary btn--lg" href="tel:+18052860477">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              Call (805) 286-0477
            </a>
            <a class="btn btn--outline btn--lg" href="#contact">Get a quote</a>
          </div>
          <p class="svc-hero__trust">California C-10 licensed &middot; Insured &middot; Serving SLO, Atascadero &amp; Paso Robles</p>
        </div>
        <div class="svc-hero__media">
          <img class="svc-hero__img" src="/assets/service-newbuild.jpg" alt="New construction electrical rough-in by Keif Electric" width="800" height="532" fetchpriority="high" />
          <div class="svc-hero__chip">
            <span class="svc-hero__chip-k">Rough-in to finish</span>
            <span class="svc-hero__chip-l">On schedule with your GC</span>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section" aria-labelledby="scope-title">
      <div class="container container--prose">
        <h2 id="scope-title" class="section-title">What I handle on new builds and remodels</h2>
        <ul class="feature-list">
          <li><strong>Rough-in wiring</strong> — full residential rough-in to plan and code</li>
          <li><strong>Panel installation</strong> — new service and <a href="/services/panel" class="inline-link">panel sized for the home</a></li>
          <li><strong>Dedicated circuits</strong> — kitchen, laundry, HVAC, EV-ready, and appliance circuits</li>
          <li><strong>Finish trim</strong> — devices, fixtures, and final connections, clean and labeled</li>
          <li><strong>ADU electrical</strong> — full electrical for accessory dwelling units</li>
          <li><strong>Remodel lighting</strong> — <a href="/services/lighting" class="inline-link">recessed lighting and fixture work</a> integrated into the remodel scope</li>
          <li><strong>Remodel integration</strong> — tying new work into existing systems without leaving a mess behind the wall</li>
        </ul>
      </div>
    </section>

    <section class="content-section content-section--alt" aria-labelledby="gc-title">
      <div class="container container--prose">
        <h2 id="gc-title" class="section-title">Built to work with your GC</h2>
        <p>I work as the electrical piece of a build, not a headache for the general contractor. That means showing up when the schedule needs me, keeping rough-in on pace so inspections don't hold up the trades behind me, and communicating clearly about what's done and what's next.</p>
        <p>If you're a GC or builder looking for a residential electrician who's reliable on schedule and clean on finish, that's the work I'm built for.</p>
      </div>
    </section>

    <section class="content-section" aria-labelledby="permits-title">
      <div class="container container--prose">
        <h2 id="permits-title" class="section-title">Permits, inspection, and code</h2>
        <p>New construction and remodel electrical is permit-and-inspection heavy by nature. I pull the electrical permits, coordinate inspections around the build schedule, and make sure every stage passes so the project keeps moving. Panels left clean and labeled for the next person who opens them.</p>
      </div>
    </section>

    <section class="why-section" aria-labelledby="why-title">
      <div class="container container--prose">
        <h2 id="why-title" class="section-title">Why builders and homeowners hire Keif Electric</h2>
        <ul class="why-list">
          <li><strong>Owner-operated.</strong> You get me on your job, not a rotating crew.</li>
          <li><strong>Licensed and insured.</strong> California C-10, CA# 1152084.</li>
          <li><strong>Reliable on schedule.</strong> Rough-in stays on pace; I don't hold up the build.</li>
          <li><strong>Clean, code-compliant finish.</strong> Labeled panels, tidy work, passes inspection.</li>
        </ul>
      </div>
    </section>

    <section class="proof-placeholder" aria-label="Recent build work">
      <div class="container">
        <p class="proof-placeholder__label">Recent build work: photos coming soon</p>
      </div>
    </section>

    <section class="faq-section" id="faq" aria-labelledby="faq-title">
      <div class="container">
        <div class="faq-inner">
          <aside class="faq-sidebar">
            <span class="eyebrow">Questions</span>
            <h2 id="faq-title" class="faq-sidebar__title">New construction FAQ</h2>
            <p>Have something else? Call and ask.</p>
            <a href="tel:+18052860477" class="btn-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              (805) 286-0477
            </a>
          </aside>
          <div class="faq-list">
            <details class="faq-item" open>
              <summary class="faq-item__btn"><span>Do you work with general contractors on new builds?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Yes, that's most of this work. I handle the electrical scope and coordinate around the build schedule so I'm not the trade that holds things up.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Do you do ADU electrical?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Yes. Full electrical for accessory dwelling units, from panel and circuits through finish, permitted and inspected.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Can you handle both rough-in and finish?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Yes, the whole electrical scope: rough-in, panel, dedicated circuits, and finish trim.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Do you pull the electrical permits on a build?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Yes. I pull the electrical permits and coordinate inspections around the project schedule.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>What areas do you serve?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>San Luis Obispo, Atascadero, Paso Robles, and surrounding SLO County.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    <section class="page-cta" id="contact" aria-labelledby="cta-title">
      <div class="container">
        <div class="page-cta__inner">
          <div>
            <span class="eyebrow eyebrow--amber">Building or remodeling?</span>
            <h2 id="cta-title" class="page-cta__title">Reliable electrical,<br/><em>on schedule.</em></h2>
            <p class="page-cta__lead">Reliable residential electrical, coordinated with your GC. Licensed, insured, owner-operated by Adam.</p>
            <div class="page-cta__btns">
              <a class="btn btn--primary btn--lg" href="tel:+18052860477">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
                Call (805) 286-0477
              </a>
              <a class="btn btn--outline-light btn--lg" href="mailto:adam@keifelectric.com?subject=New%20construction%20electrical%20quote">Email a quote request</a>
            </div>
          </div>
          <div class="page-cta__card">
            <p class="page-cta__card-eyebrow">Free estimate</p>
            <a href="tel:+18052860477" class="page-cta__phone">(805) 286-0477</a>
            <div class="page-cta__trust">
              <span>California C-10 licensed</span>
              <span>Liability insured</span>
              <span>Mon–Fri, 9am–5pm</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <noscript>
    <style>
      .content-section .container--prose,
      .why-section .container--prose,
      .proof-placeholder .container,
      .faq-inner,
      .page-cta__inner { opacity: 1 !important; transform: none !important; }
    </style>
  </noscript>

  <Footer />
</BaseLayout>

<style>
  .container { max-width: var(--max); margin: 0 auto; padding-left: var(--gutter); padding-right: var(--gutter); }
  .container--prose { max-width: 760px; }
  .breadcrumb { background: var(--ke-bone); border-bottom: 1px solid var(--border-1); padding: 12px 0; }
  .breadcrumb .container { display: flex; gap: 8px; align-items: center; font-size: 13px; color: var(--fg-2); }
  .breadcrumb a { color: var(--ke-orange); font-weight: 500; }
  .breadcrumb a:hover { text-decoration: underline; }
  .svc-hero { position: relative; background: var(--ke-bone); overflow: hidden; padding: 72px 0 88px; }
  .svc-hero::before { content: ''; position: absolute; top: -25%; right: -12%; width: 62%; height: 130%; background: radial-gradient(closest-side, rgba(243, 152, 31, 0.12), transparent 72%); pointer-events: none; }
  .svc-hero__inner { position: relative; display: grid; grid-template-columns: 1.05fr 0.85fr; gap: 56px; align-items: center; }
  .svc-hero__eyebrow { display: inline-flex; align-items: center; gap: 8px; font-weight: 700; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ke-clay); margin-bottom: 18px; }
  .svc-hero__spark { width: 15px; height: 15px; color: var(--ke-orange); }
  .svc-hero__title { font-family: var(--font-display); font-weight: 400; font-variation-settings: "YEAR" 2050; font-size: clamp(46px, 6.4vw, 92px); line-height: 0.9; letter-spacing: -0.005em; color: var(--ke-ink); margin: 0; }
  .svc-hero__line { display: block; }
  .svc-hero__line--accent { color: var(--ke-orange); }
  .svc-hero__dot { display: inline-block; width: 0.16em; height: 0.16em; background: var(--ke-orange); border-radius: 2px; margin-left: 0.05em; vertical-align: baseline; }
  .svc-hero__place { display: block; font-family: var(--font-sans); font-weight: 600; font-size: clamp(15px, 1.6vw, 19px); letter-spacing: 0; color: var(--fg-2); margin-top: 16px; }
  .svc-hero__sub { font-size: 18px; line-height: 1.55; color: var(--ke-ink); max-width: 46ch; margin: 26px 0 26px; font-weight: 500; }
  .svc-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .svc-hero__trust { margin-top: 26px; font-size: 13px; font-weight: 600; color: var(--fg-2); letter-spacing: 0.01em; }
  .svc-hero__media { position: relative; justify-self: end; width: 100%; max-width: 440px; }
  .svc-hero__img { width: 100%; height: auto; border-radius: var(--radius-4); box-shadow: var(--shadow-3); border: 1px solid var(--border-1); }
  .svc-hero__chip { position: absolute; left: -16px; bottom: 28px; background: var(--ke-ink); color: var(--ke-bone); padding: 12px 16px; border-radius: var(--radius-3); box-shadow: var(--shadow-3); display: flex; flex-direction: column; gap: 2px; }
  .svc-hero__chip-k { font-weight: 800; font-size: 15px; color: var(--ke-amber); letter-spacing: 0.02em; }
  .svc-hero__chip-l { font-size: 12px; color: rgba(246, 241, 232, 0.8); }
  .btn--outline { background: transparent; color: var(--ke-ink); border-color: var(--ke-ink); }
  .btn--outline:hover { background: var(--ke-ink); color: var(--ke-bone); }
  @media (prefers-reduced-motion: no-preference) {
    .svc-hero__eyebrow, .svc-hero__line, .svc-hero__place, .svc-hero__sub, .svc-hero__ctas, .svc-hero__trust, .svc-hero__media { opacity: 0; animation: heroIn 0.8s var(--ease-emph) forwards; }
    .svc-hero__eyebrow { animation-delay: 0.05s; }
    .svc-hero__line:nth-child(1) { animation-delay: 0.13s; }
    .svc-hero__line:nth-child(2) { animation-delay: 0.21s; }
    .svc-hero__place { animation-delay: 0.29s; }
    .svc-hero__sub { animation-delay: 0.37s; }
    .svc-hero__ctas { animation-delay: 0.45s; }
    .svc-hero__trust { animation-delay: 0.53s; }
    .svc-hero__media { animation-delay: 0.22s; animation-duration: 1s; }
    .content-section .container--prose, .why-section .container--prose, .proof-placeholder .container, .faq-inner, .page-cta__inner { opacity: 0; transform: translateY(22px); transition: opacity 0.7s var(--ease-emph), transform 0.7s var(--ease-emph); }
    .is-in { opacity: 1 !important; transform: none !important; }
  }
  @keyframes heroIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  .btn { font-family: var(--font-sans); font-weight: 600; font-size: 15px; padding: 13px 18px; border-radius: var(--radius-2); border: 1px solid transparent; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 9px; line-height: 1; min-height: 48px; transition: all var(--dur-1) var(--ease-out); text-decoration: none; white-space: nowrap; }
  .btn svg { width: 18px; height: 18px; flex: none; }
  .btn--primary { background: var(--ke-orange); color: #fff; }
  .btn--primary:hover { background: var(--ke-orange-dark); }
  .btn--primary:active { transform: translateY(1px); }
  .btn--outline-light { background: transparent; color: var(--ke-bone); border-color: rgba(246, 241, 232, 0.4); }
  .btn--outline-light:hover { background: rgba(246, 241, 232, 0.08); border-color: var(--ke-bone); }
  .btn--lg { padding: 16px 22px; font-size: 16px; border-radius: var(--radius-3); min-height: 54px; }
  .btn-link { display: inline-flex; align-items: center; gap: 8px; color: var(--ke-orange); font-weight: 600; font-size: 15px; text-decoration: none; }
  .btn-link svg { width: 16px; height: 16px; }
  .btn-link:hover { text-decoration: underline; }
  .content-section { padding: 80px 0; background: var(--ke-bone); }
  .content-section--alt { background: var(--ke-paper); }
  .section-title { font-family: var(--font-sans); font-weight: 800; font-size: clamp(24px, 3vw, 34px); letter-spacing: -0.02em; line-height: 1.15; color: var(--ke-ink); margin-bottom: 20px; }
  .lead-copy { font-size: 17px; line-height: 1.6; color: var(--fg-1); margin-bottom: 20px; }
  .content-section p { font-size: 16px; line-height: 1.65; color: var(--fg-1); margin-bottom: 16px; max-width: 68ch; }
  .content-section p:last-child { margin-bottom: 0; }
  .feature-list { list-style: none; padding: 0; margin: 0 0 20px; display: flex; flex-direction: column; gap: 12px; }
  .feature-list li { font-size: 16px; line-height: 1.6; color: var(--fg-1); padding-left: 20px; position: relative; }
  .feature-list li::before { content: ''; position: absolute; left: 0; top: 10px; width: 8px; height: 2px; background: var(--ke-orange); }
  .inline-link { color: var(--ke-orange); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .why-section { background: var(--ke-ink); color: var(--ke-bone); padding: 80px 0; }
  .why-section .section-title { color: var(--ke-bone); }
  .why-list { list-style: none; padding: 0; margin: 24px 0 0; display: flex; flex-direction: column; gap: 16px; }
  .why-list li { font-size: 16px; line-height: 1.6; color: rgba(246, 241, 232, 0.82); padding-left: 20px; position: relative; }
  .why-list li::before { content: ''; position: absolute; left: 0; top: 10px; width: 8px; height: 2px; background: var(--ke-orange); }
  .why-list li strong { color: var(--ke-bone); }
  .proof-placeholder { background: var(--ke-sand); border-top: 1px solid var(--border-1); border-bottom: 1px solid var(--border-1); padding: 40px 0; text-align: center; }
  .proof-placeholder__label { font-size: 13px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ke-stone); }
  .faq-section { background: var(--ke-bone); padding: 100px 0; }
  .faq-inner { display: grid; grid-template-columns: 1fr 1.6fr; gap: 64px; align-items: flex-start; }
  .faq-sidebar { position: sticky; top: 96px; }
  .faq-sidebar__title { font-family: var(--font-sans); font-weight: 900; font-size: clamp(28px, 3vw, 40px); letter-spacing: -0.02em; line-height: 1.1; color: var(--ke-ink); margin: 10px 0 14px; }
  .faq-sidebar p { font-size: 15px; color: var(--fg-2); margin-bottom: 20px; }
  .eyebrow { font-family: var(--font-sans); font-weight: 700; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ke-orange); display: inline-block; }
  .eyebrow--amber { color: var(--ke-amber); }
  .faq-list { display: flex; flex-direction: column; border-top: 1px solid var(--border-1); }
  .faq-item { border-bottom: 1px solid var(--border-1); }
  .faq-item__btn { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 0; cursor: pointer; font-size: 16px; font-weight: 600; color: var(--ke-ink); list-style: none; user-select: none; }
  .faq-item__btn::-webkit-details-marker { display: none; }
  .faq-icon { width: 20px; height: 20px; flex: none; border-radius: 50%; border: 1.5px solid var(--border-2); position: relative; }
  .faq-icon::before, .faq-icon::after { content: ''; position: absolute; top: 50%; left: 50%; background: var(--ke-orange); border-radius: 2px; }
  .faq-icon::before { width: 8px; height: 1.5px; transform: translate(-50%, -50%); }
  .faq-icon::after { width: 1.5px; height: 8px; transform: translate(-50%, -50%); transition: transform var(--dur-1) var(--ease-out), opacity var(--dur-1) var(--ease-out); }
  details[open] .faq-icon::after { transform: translate(-50%, -50%) rotate(90deg); opacity: 0; }
  .faq-item__body { padding-bottom: 20px; }
  .faq-item__body p { font-size: 15px; line-height: 1.65; color: var(--fg-2); }
  .page-cta { background: var(--ke-ink); color: var(--ke-bone); padding: 100px 0; }
  .page-cta__inner { display: grid; grid-template-columns: 1fr auto; gap: 64px; align-items: center; }
  .page-cta__title { font-family: var(--font-display); font-variation-settings: 'YEAR' 2050; font-size: clamp(44px, 6vw, 88px); line-height: 0.95; color: var(--ke-bone); margin: 12px 0 18px; letter-spacing: -0.005em; }
  .page-cta__title em { font-style: normal; color: var(--ke-orange); }
