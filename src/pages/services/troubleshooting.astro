---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const title = 'Electrical Troubleshooting & Repair in San Luis Obispo County | Keif Electric';
const description = 'Flickering lights, tripping breakers, dead outlets: root cause diagnosis, not just a bandaid. Flat diagnostic fee. Owner-operated by Adam Keif. Serving SLO County.';
const canonical = 'https://keifelectric.com/services/troubleshooting';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Electrical Troubleshooting & Repair',
  description: 'Electrical troubleshooting and diagnostic service for flickering lights, tripping breakers, dead outlets, and mystery circuits. Root cause diagnosis with flat diagnostic fee. Serving San Luis Obispo County.',
  provider: {
    '@type': 'Electrician',
    name: 'Keif Electric',
    telephone: '+18052860477',
    areaServed: 'San Luis Obispo County, CA',
  },
  areaServed: 'San Luis Obispo County, CA',
  serviceType: 'Electrical Troubleshooting',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'My lights keep flickering. Is that dangerous?',
      acceptedAnswer: { '@type': 'Answer', text: 'It can be. Flickering is sometimes minor, but it can signal a loose connection or a panel issue that\'s worth catching early. I find the actual cause rather than guessing.' },
    },
    {
      '@type': 'Question',
      name: 'Why does my breaker keep tripping?',
      acceptedAnswer: { '@type': 'Answer', text: 'A breaker trips to protect the circuit, from an overload, a short, or a ground fault. Repeated tripping means something needs attention. I trace it to the source instead of just resetting it.' },
    },
    {
      '@type': 'Question',
      name: 'Do you charge for a diagnostic visit?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes, a flat diagnostic fee, and it applies toward the repair if you move forward. You get a quote on the fix before I do the work.' },
    },
    {
      '@type': 'Question',
      name: 'How fast can you come out?',
      acceptedAnswer: { '@type': 'Answer', text: 'For most non-emergency issues, usually within the same week. For anything urgent like a burning smell, call and I\'ll advise you right away.' },
    },
    {
      '@type': 'Question',
      name: 'Do you also install outlets, switches, and GFCIs?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. New outlets and switches, GFCI and AFCI upgrades, USB outlets, and dedicated circuits for appliances and home offices, all code-compliant.' },
    },
    {
      '@type': 'Question',
      name: 'What areas do you serve?',
      acceptedAnswer: { '@type': 'Answer', text: 'San Luis Obispo, Atascadero, Paso Robles, and surrounding SLO County.' },
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical} includeFaqSchema={false}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />

  <main id="main">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="container">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#services">Services</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Troubleshooting &amp; Repair</span>
      </div>
    </nav>

    <section class="page-hero" id="top" aria-labelledby="page-h1">
      <div class="container">
        <h1 id="page-h1" class="page-hero__title">Electrical Troubleshooting &amp; Repair in San Luis Obispo County</h1>
        <p class="page-hero__sub">Flickering lights, tripping breakers, dead outlets, mystery circuits. I find the root cause, not just the symptom. Licensed, owner-operated by Adam Keif.</p>
        <div class="hero-ctas">
          <a class="btn btn--primary btn--lg" href="tel:+18052860477">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
            Call (805) 286-0477
          </a>
          <a class="btn btn--outline-light btn--lg" href="#contact">Get a free quote</a>
        </div>
        <p class="trust-line">California C-10 licensed &middot; Insured &middot; Serving SLO, Atascadero &amp; Paso Robles</p>
      </div>
    </section>

    <section class="content-section" aria-labelledby="problems-title">
      <div class="container container--prose">
        <h2 id="problems-title" class="section-title">Problems I fix</h2>
        <ul class="feature-list">
          <li><strong>Flickering or dimming lights</strong> — often a loose connection or a failing circuit, sometimes a sign of something in the panel</li>
          <li><strong>Breakers that keep tripping</strong> — a breaker trips for a reason; I find what's overloading or faulting the circuit</li>
          <li><strong>Dead outlets or partial power</strong> — half a room out, an outlet with no power, a tripped circuit that won't reset</li>
          <li><strong>Burning smell or warm outlets/switches</strong> — don't wait on this one. Call and stop using the outlet.</li>
          <li><strong>Buzzing or warm panel</strong> — it may point to <a href="/services/panel" class="inline-link">a panel that needs upgrading</a>. Worth looking at before it becomes a bigger problem.</li>
          <li><strong>Outlets and switches</strong> — new installs, replacements, GFCI and AFCI upgrades, USB outlets, dedicated circuits for appliances</li>
          <li><strong>Mystery circuits</strong> — the switch that controls nothing, the circuit no one can trace</li>
        </ul>
      </div>
    </section>

    <section class="content-section content-section--alt" aria-labelledby="rootcause-title">
      <div class="container container--prose">
        <h2 id="rootcause-title" class="section-title">Root cause, not a bandaid</h2>
        <p>A lot of electrical problems get "fixed" by swapping the part that failed without finding why it failed. That's how you end up calling three electricians for the same flickering light.</p>
        <p>I diagnose the actual cause. Sometimes that's a five-minute fix: a loose neutral, a bad connection. Sometimes it points to something bigger like a panel that's on its way out. Either way, you'll know what's actually going on and what it'll take to fix it for good.</p>
      </div>
    </section>

    <section class="content-section" aria-labelledby="pricing-title">
      <div class="container container--prose">
        <h2 id="pricing-title" class="section-title">How diagnostic pricing works</h2>
        <p>For troubleshooting and diagnostic calls, I charge a flat diagnostic fee to come out and find the problem. If you move forward with the repair, that fee applies toward the work. You get a clear quote on the fix before I do it, with no open-ended hourly surprises.</p>
      </div>
    </section>

    <section class="content-section content-section--alt" aria-labelledby="scheduling-title">
      <div class="container container--prose">
        <h2 id="scheduling-title" class="section-title">Same-week scheduling</h2>
        <p>For most non-emergency electrical issues, I can usually get out within the same week across San Luis Obispo, Atascadero, Paso Robles, and the surrounding area. If it's something urgent like a burning smell or exposed wiring, call and I'll tell you straight what to do in the meantime.</p>
      </div>
    </section>

    <section class="why-section" aria-labelledby="why-title">
      <div class="container container--prose">
        <h2 id="why-title" class="section-title">Why homeowners hire Keif Electric</h2>
        <ul class="why-list">
          <li><strong>You hire me, not a crew.</strong> I diagnose it and I fix it.</li>
          <li><strong>Licensed and insured.</strong> California C-10, CA# 1152084.</li>
          <li><strong>Honest diagnosis.</strong> If it's small, I'll tell you it's small.</li>
          <li><strong>Explains everything.</strong> You'll understand what was wrong and what I did.</li>
        </ul>
      </div>
    </section>

    <section class="proof-placeholder" aria-label="Recent repairs">
      <div class="container">
        <p class="proof-placeholder__label">Recent repairs: photos coming soon</p>
      </div>
    </section>

    <section class="faq-section" id="faq" aria-labelledby="faq-title">
      <div class="container">
        <div class="faq-inner">
          <aside class="faq-sidebar">
            <span class="eyebrow">Questions</span>
            <h2 id="faq-title" class="faq-sidebar__title">Troubleshooting FAQ</h2>
            <p>Have something else? Call and ask.</p>
            <a href="tel:+18052860477" class="btn-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              (805) 286-0477
            </a>
          </aside>
          <div class="faq-list">
            <details class="faq-item" open>
              <summary class="faq-item__btn"><span>My lights keep flickering. Is that dangerous?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>It can be. Flickering is sometimes minor, but it can signal a loose connection or a panel issue that's worth catching early. I find the actual cause rather than guessing.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Why does my breaker keep tripping?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>A breaker trips to protect the circuit, from an overload, a short, or a ground fault. Repeated tripping means something needs attention. I trace it to the source instead of just resetting it.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Do you charge for a diagnostic visit?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Yes, a flat diagnostic fee, and it applies toward the repair if you move forward. You get a quote on the fix before I do the work.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>How fast can you come out?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>For most non-emergency issues, usually within the same week. For anything urgent like a burning smell, call and I'll advise you right away.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Do you also install outlets, switches, and GFCIs?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Yes. New outlets and switches, GFCI and AFCI upgrades, USB outlets, and dedicated circuits for appliances and home offices, all code-compliant.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>What areas do you serve?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>San Luis Obispo, Atascadero, Paso Robles, and surrounding SLO County.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    <section class="page-cta" id="contact" aria-labelledby="cta-title">
      <div class="container">
        <div class="page-cta__inner">
          <div>
            <span class="eyebrow eyebrow--amber">Something not working right?</span>
            <h2 id="cta-title" class="page-cta__title">Free estimates<br/><em>on repairs.</em></h2>
            <p class="page-cta__lead">Free estimates on repairs. Licensed, insured, owner-operated by Adam.</p>
            <div class="page-cta__btns">
              <a class="btn btn--primary btn--lg" href="tel:+18052860477">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
                Call (805) 286-0477
              </a>
              <a class="btn btn--outline-light btn--lg" href="mailto:adam@keifelectric.com?subject=Electrical%20repair%20quote%20request">Email a quote request</a>
            </div>
          </div>
          <div class="page-cta__card">
            <p class="page-cta__card-eyebrow">Free estimate</p>
            <a href="tel:+18052860477" class="page-cta__phone">(805) 286-0477</a>
            <div class="page-cta__trust">
              <span>California C-10 licensed</span>
              <span>Liability insured</span>
              <span>Mon–Fri, 9am–5pm</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .container { max-width: var(--max); margin: 0 auto; padding-left: var(--gutter); padding-right: var(--gutter); }
  .container--prose { max-width: 760px; }
  .breadcrumb { background: var(--ke-bone); border-bottom: 1px solid var(--border-1); padding: 12px 0; }
  .breadcrumb .container { display: flex; gap: 8px; align-items: center; font-size: 13px; color: var(--fg-2); }
  .breadcrumb a { color: var(--ke-orange); font-weight: 500; }
  .breadcrumb a:hover { text-decoration: underline; }
  .page-hero { background: var(--ke-ink); color: var(--ke-bone); padding: 80px 0 72px; }
  .page-hero__title { font-family: var(--font-sans); font-weight: 800; font-size: clamp(32px, 5vw, 56px); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 18px; max-width: 22ch; }
  .page-hero__sub { font-size: clamp(16px, 2vw, 19px); line-height: 1.55; color: rgba(246, 241, 232, 0.82); max-width: 52ch; margin-bottom: 32px; }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }
  .trust-line { font-size: 13px; color: rgba(246, 241, 232, 0.58); font-weight: 500; letter-spacing: 0.02em; }
  .btn { font-family: var(--font-sans); font-weight: 600; font-size: 15px; padding: 13px 18px; border-radius: var(--radius-2); border: 1px solid transparent; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 9px; line-height: 1; min-height: 48px; transition: all var(--dur-1) var(--ease-out); text-decoration: none; white-space: nowrap; }
  .btn svg { width: 18px; height: 18px; flex: none; }
  .btn--primary { background: var(--ke-orange); color: #fff; }
  .btn--primary:hover { background: var(--ke-orange-dark); }
  .btn--primary:active { transform: translateY(1px); }
  .btn--outline-light { background: transparent; color: var(--ke-bone); border-color: rgba(246, 241, 232, 0.4); }
  .btn--outline-light:hover { background: rgba(246, 241, 232, 0.08); border-color: var(--ke-bone); }
  .btn--lg { padding: 16px 22px; font-size: 16px; border-radius: var(--radius-3); min-height: 54px; }
  .btn-link { display: inline-flex; align-items: center; gap: 8px; color: var(--ke-orange); font-weight: 600; font-size: 15px; text-decoration: none; }
  .btn-link svg { width: 16px; height: 16px; }
  .btn-link:hover { text-decoration: underline; }
  .content-section { padding: 80px 0; background: var(--ke-bone); }
  .content-section--alt { background: var(--ke-paper); }
  .section-title { font-family: var(--font-sans); font-weight: 800; font-size: clamp(24px, 3vw, 34px); letter-spacing: -0.02em; line-height: 1.15; color: var(--ke-ink); margin-bottom: 20px; }
  .lead-copy { font-size: 17px; line-height: 1.6; color: var(--fg-1); margin-bottom: 20px; }
  .content-section p { font-size: 16px; line-height: 1.65; color: var(--fg-1); margin-bottom: 16px; max-width: 68ch; }
  .content-section p:last-child { margin-bottom: 0; }
  .feature-list { list-style: none; padding: 0; margin: 0 0 20px; display: flex; flex-direction: column; gap: 12px; }
  .feature-list li { font-size: 16px; line-height: 1.6; color: var(--fg-1); padding-left: 20px; position: relative; }
  .feature-list li::before { content: ''; position: absolute; left: 0; top: 10px; width: 8px; height: 2px; background: var(--ke-orange); }
  .inline-link { color: var(--ke-orange); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .why-section { background: var(--ke-ink); color: var(--ke-bone); padding: 80px 0; }
  .why-section .section-title { color: var(--ke-bone); }
  .why-list { list-style: none; padding: 0; margin: 24px 0 0; display: flex; flex-direction: column; gap: 16px; }
  .why-list li { font-size: 16px; line-height: 1.6; color: rgba(246, 241, 232, 0.82); padding-left: 20px; position: relative; }
  .why-list li::before { content: ''; position: absolute; left: 0; top: 10px; width: 8px; height: 2px; background: var(--ke-orange); }
  .why-list li strong { color: var(--ke-bone); }
  .proof-placeholder { background: var(--ke-sand); border-top: 1px solid var(--border-1); border-bottom: 1px solid var(--border-1); padding: 40px 0; text-align: center; }
  .proof-placeholder__label { font-size: 13px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ke-stone); }
  .faq-section { background: var(--ke-bone); padding: 100px 0; }
  .faq-inner { display: grid; grid-template-columns: 1fr 1.6fr; gap: 64px; align-items: flex-start; }
  .faq-sidebar { position: sticky; top: 96px; }
  .faq-sidebar__title { font-family: var(--font-sans); font-weight: 900; font-size: clamp(28px, 3vw, 40px); letter-spacing: -0.02em; line-height: 1.1; color: var(--ke-ink); margin: 10px 0 14px; }
  .faq-sidebar p { font-size: 15px; color: var(--fg-2); margin-bottom: 20px; }
  .eyebrow { font-family: var(--font-sans); font-weight: 700; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ke-orange); display: inline-block; }
  .eyebrow--amber { color: var(--ke-amber); }
  .faq-list { display: flex; flex-direction: column; border-top: 1px solid var(--border-1); }
  .faq-item { border-bottom: 1px solid var(--border-1); }
  .faq-item__btn { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 0; cursor: pointer; font-size: 16px; font-weight: 600; color: var(--ke-ink); list-style: none; user-select: none; }
  .faq-item__btn::-webkit-details-marker { display: none; }
  .faq-icon { width: 20px; height: 20px; flex: none; border-radius: 50%; border: 1.5px solid var(--border-2); position: relative; }
  .faq-icon::before, .faq-icon::after { content: ''; position: absolute; top: 50%; left: 50%; background: var(--ke-orange); border-radius: 2px; }
  .faq-icon::before { width: 8px; height: 1.5px; transform: translate(-50%, -50%); }
  .faq-icon::after { width: 1.5px; height: 8px; transform: translate(-50%, -50%); transition: transform var(--dur-1) var(--ease-out), opacity var(--dur-1) var(--ease-out); }
  details[open] .faq-icon::after { transform: translate(-50%, -50%) rotate(90deg); opacity: 0; }
  .faq-item__body { padding-bottom: 20px; }
  .faq-item__body p { font-size: 15px; line-height: 1.65; color: var(--fg-2); }
  .page-cta { background: var(--ke-ink); color: var(--ke-bone); padding: 100px 0; }
  .page-cta__inner { display: grid; grid-template-columns: 1fr auto; gap: 64px; align-items: center; }
  .page-cta__title { font-family: var(--font-display); font-variation-settings: 'YEAR' 2050; font-size: clamp(44px, 6vw, 88px); line-height: 0.95; color: var(--ke-bone); margin: 12px 0 18px; letter-spacing: -0.005em; }
  .page-cta__title em { font-style: normal; color: var(--ke-orange); }
  .page-cta__lead { font-size: 17px; color: rgba(246, 241, 232, 0.75); line-height: 1.55; margin-bottom: 28px; max-width: 44ch; }
  .page-cta__btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .page-cta__card { background: var(--ke-bone); color: var(--ke-ink); border-radius: var(--radius-4); padding: 32px 28px; min-width: 260px; flex-shrink: 0; }
  .page-cta__card-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ke-orange); margin-bottom: 10px; }
  .page-cta__phone { display: block; font-family: var(--font-display); font-variation-settings: 'YEAR' 2030; font-size: clamp(32px, 3.5vw, 44px); line-height: 1; color: var(--ke-ink); text-decoration: none; margin-bottom: 16px; transition: color var(--dur-1) var(--ease-out); }
  .page-cta__phone:hover { color: var(--ke-orange); }
  .page-cta__trust { display: flex; flex-direction: column; gap: 5px; font-size: 13px; color: var(--fg-2); font-weight: 500; padding-top: 16px; border-top: 1px solid var(--border-1); }
  @media (max-width: 900px) { .page-cta__inner { grid-template-columns: 1fr; gap: 40px; } }
  @media (max-width: 768px) {
    .page-hero { padding: 56px 0 48px; }
    .content-section { padding: 56px 0; }
    .why-section { padding: 56px 0; }
    .faq-section { padding: 64px 0; }
    .page-cta { padding: 64px 0; }
    .hero-ctas { flex-direction: column; }
    .btn--lg { width: 100%; justify-content: center; }
    .page-cta__btns { flex-direction: column; }
    .faq-inner { grid-template-columns: 1fr; gap: 32px; }
    .faq-sidebar { position: static; }
  }
</style>
