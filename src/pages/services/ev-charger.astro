---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';

const title = 'EV Charger Installation in San Luis Obispo County | Keif Electric';
const description = 'Level 2 EV charger installation in SLO County. Tesla Wall Connectors, NEMA 14-50 outlets, and dedicated 240V circuits. Permitted, inspected, owner-operated by Adam Keif.';
const canonical = 'https://keifelectric.com/services/ev-charger';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'EV Charger Installation',
  description: 'Level 2 home EV charger installation including panel assessment, dedicated 240V circuit, permit, inspection, and charger mounting. Serving San Luis Obispo County.',
  provider: {
    '@type': 'Electrician',
    name: 'Keif Electric',
    telephone: '+18052860477',
    areaServed: 'San Luis Obispo County, CA',
  },
  areaServed: 'San Luis Obispo County, CA',
  serviceType: 'EV Charger Installation',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Do you install Tesla Wall Connectors?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. I install Tesla Wall Connectors along with the electrical work behind them, the dedicated circuit, breaker, conduit, and panel connection. I also install chargers for Rivian, Ford, and every other EV. If you\'ve already bought your unit, I\'ll install it. If not, I\'ll help you pick the right one.' },
    },
    {
      '@type': 'Question',
      name: 'Do I need a 200-amp panel for an EV charger?',
      acceptedAnswer: { '@type': 'Answer', text: 'Not always. Plenty of homes can support EV charging without a panel upgrade. I do a load assessment first to confirm your home\'s actual capacity rather than assuming either way.' },
    },
    {
      '@type': 'Question',
      name: 'Should I install a plug-in charger or a hardwired one?',
      acceptedAnswer: { '@type': 'Answer', text: 'Both work. Hardwired chargers like the Tesla Wall Connector generally allow higher charging speeds and make for a cleaner permanent install. A NEMA 14-50 outlet can make sense for some setups, especially if you want flexibility. I\'ll walk you through which fits your situation.' },
    },
    {
      '@type': 'Question',
      name: 'How long does an EV charger installation take?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most standard installs are done in a few hours to most of a day, depending on the run from your panel and whether any panel work is needed. If a panel upgrade is required first, that adds time and I\'ll lay it out in the quote.' },
    },
    {
      '@type': 'Question',
      name: 'Do I need a permit to install an EV charger?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most residential EV charger installs in SLO County need an electrical permit and inspection. I handle the permit, inspection, and utility coordination so it\'s code-compliant and signed off.' },
    },
    {
      '@type': 'Question',
      name: 'What areas do you cover for EV charger installation?',
      acceptedAnswer: { '@type': 'Answer', text: 'San Luis Obispo, Atascadero, Paso Robles, and the surrounding SLO County area. If you\'re not sure I reach you, call and ask.' },
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical} includeFaqSchema={false}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />

  <main id="main">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <div class="container">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#services">Services</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">EV Charger Installation</span>
      </div>
    </nav>

    <section class="svc-hero" id="top" aria-labelledby="page-h1">
      <div class="svc-hero__inner container">
        <div class="svc-hero__copy">
          <p class="svc-hero__eyebrow">
            <svg class="svc-hero__spark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2 4.5 13.5H11l-1 8.5 8.5-11.5H12l1-8.5Z"/></svg>
            EV Charger Installation
          </p>
          <h1 id="page-h1" class="svc-hero__title">
            <span class="svc-hero__line">Tesla &amp; EV charger</span>
            <span class="svc-hero__line svc-hero__line--accent">installation<span class="svc-hero__dot" aria-hidden="true"></span></span>
            <span class="svc-hero__place">in San Luis Obispo County</span>
          </h1>
          <p class="svc-hero__sub">Level 2 charging for Tesla, Rivian, Ford, and every EV. Tesla Wall Connectors, NEMA 14-50 outlets, and dedicated 240V circuits, with permits and inspection handled start to finish.</p>
          <div class="svc-hero__ctas">
            <a class="btn btn--primary btn--lg" href="tel:+18052860477">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              Call (805) 286-0477
            </a>
            <a class="btn btn--outline btn--lg" href="#contact">Get a free quote</a>
          </div>
          <p class="svc-hero__trust">California C-10 licensed &middot; Insured &middot; Serving SLO, Atascadero &amp; Paso Robles</p>
        </div>
        <div class="svc-hero__media">
          <img class="svc-hero__img" src="/assets/service-ev-charger.jpg" alt="Level 2 EV charger installed cleanly in a residential garage" width="533" height="800" fetchpriority="high" />
          <div class="svc-hero__chip">
            <span class="svc-hero__chip-k">Level 2</span>
            <span class="svc-hero__chip-l">Permitted &amp; inspected</span>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section" aria-labelledby="includes-title">
      <div class="container container--prose">
        <h2 id="includes-title" class="section-title">What the install includes</h2>
        <p class="lead-copy">Most EV charger installs are more than mounting a box on the wall. Here's what a Keif Electric install actually covers:</p>
        <ul class="feature-list">
          <li><strong>Panel assessment</strong> — I check whether your electrical panel and service can handle the added load before quoting. No surprises mid-job.</li>
          <li><strong>Dedicated 240V circuit</strong> — a properly sized dedicated circuit run for your charger, not a shared line that trips under load.</li>
          <li><strong>Hardwired or plug-in setup</strong> — some homeowners go with a NEMA 14-50 outlet, others with a hardwired charger like the Tesla Wall Connector. I'll recommend what fits your vehicle and your electrical system.</li>
          <li><strong>Clean conduit runs</strong> — conduit routed neatly along the garage or exterior, not slapped across the wall.</li>
          <li><strong>Permit and inspection</strong> — I pull the permit, coordinate the inspection, and make sure the install is signed off to code.</li>
          <li><strong>Charger mounting and testing</strong> — hardware mounted, wired, energized, and tested before I leave.</li>
        </ul>
        <p>Whether you already have your charger in hand or you want a recommendation on which one fits your setup, I handle the full job from permit to first charge.</p>
      </div>
    </section>

    <section class="content-section content-section--alt" aria-labelledby="chargers-title">
      <div class="container container--prose">
        <h2 id="chargers-title" class="section-title">EV chargers I install</h2>
        <p class="lead-copy">Whether you already own your charger or need help choosing one, I install residential EV charging equipment including:</p>
        <ul class="feature-list">
          <li>Tesla Wall Connector</li>
          <li>ChargePoint Home</li>
          <li>Wallbox</li>
          <li>Emporia</li>
          <li>Ford and Rivian home charging</li>
        </ul>
        <p>The right setup depends on your vehicle, how much you drive, your panel capacity, and where the charger needs to go. If you haven't bought yet, ask me before you do.</p>
      </div>
    </section>

    <section class="content-section" aria-labelledby="cost-title">
      <div class="container container--prose">
        <h2 id="cost-title" class="section-title">How much does EV charger installation cost in San Luis Obispo?</h2>
        <p class="lead-copy">Straight answer: most home Level 2 installs land in the <strong>$700 to $1,500</strong> range for a standard job where your panel has capacity and the run to the garage is reasonable.</p>
        <p>Tesla Wall Connector installs fall into the same range as other Level 2 chargers. The cost comes from the electrical work, not the brand on the box.</p>
        <p>What moves the price:</p>
        <ul class="feature-list">
          <li><strong>Distance from your panel to the charger</strong> — longer conduit runs cost more in materials and labor.</li>
          <li><strong>Panel capacity</strong> — if your panel is full or under-sized, you may need a panel upgrade first. <a href="/services/panel" class="inline-link">If your panel can't support the added load, we may need to upgrade your electrical panel first.</a></li>
          <li><strong>Indoor vs. outdoor mounting</strong> — exterior installs need weatherproofing.</li>
          <li><strong>Hardwired vs. plug-in</strong> — and whether you've already bought the unit.</li>
        </ul>
        <p>You get a written quote before any work starts. No hidden fees, no add-ons that weren't discussed.</p>
      </div>
    </section>

    <section class="content-section content-section--alt" aria-labelledby="panel-title">
      <div class="container container--prose">
        <h2 id="panel-title" class="section-title">Will your panel handle it?</h2>
        <p>An EV charger is one of the biggest loads you can add to a home. Plenty of older homes around San Luis Obispo, Atascadero, and Paso Robles still run 100-amp panels that are already close to full.</p>
        <p>Before I install a charger, I do a load assessment on your panel and service. If there's room, we install and you're charging the same day. If there isn't, I'll walk you through what a panel upgrade involves and quote both together so you can decide with the full picture.</p>
        <p>If the assessment turns up other problems, a loose neutral, a failing breaker, wiring that isn't right, I'll tell you. <a href="/services/troubleshooting" class="inline-link">I can also handle electrical issues found during your panel evaluation.</a></p>
        <a href="/services/panel" class="cta-link">Learn more about electrical panel upgrades &rarr;</a>
      </div>
    </section>

    <section class="content-section" aria-labelledby="permits-title">
      <div class="container container--prose">
        <h2 id="permits-title" class="section-title">Permits and inspection</h2>
        <p>Most residential EV charger installations in San Luis Obispo County require an electrical permit and inspection. That's not red tape to dodge. Unpermitted work can cause problems with your homeowner's insurance and at resale.</p>
        <p>I pull the permit, coordinate with the utility where needed, schedule the inspection, and make sure everything is signed off. You don't chase any of it.</p>
      </div>
    </section>

    <section class="content-section content-section--alt" aria-labelledby="rebates-title">
      <div class="container container--prose">
        <h2 id="rebates-title" class="section-title">EV charger rebates and incentives</h2>
        <p>EV charger incentives change often. Federal, state, utility, and local programs come and go, and most have eligibility rules or expiration dates attached.</p>
        <p>One thing worth knowing right now: the federal EV charger tax credit (30C) expired on June 30, 2026. If you're reading older articles or other installers' pages that still advertise it, they're out of date.</p>
        <p>Before your installation, I'll tell you what's actually available and what you'd qualify for. I'd rather you hear "there's nothing right now" from me than budget around a credit that doesn't exist.</p>
      </div>
    </section>

    <section class="why-section" aria-labelledby="why-title">
      <div class="container container--prose">
        <h2 id="why-title" class="section-title">Why homeowners hire Keif Electric</h2>
        <ul class="why-list">
          <li><strong>You hire me, not a crew.</strong> Every job is done by me, personally. The person who quotes it is the person who installs it.</li>
          <li><strong>Local SLO County electrician.</strong> I work throughout San Luis Obispo County and know what's common in local homes, from older 100-amp panels to garage layouts that need a longer conduit run.</li>
          <li><strong>Licensed and insured.</strong> California C-10 electrical contractor, CA# 1152084, with liability insurance.</li>
          <li><strong>Permitted and inspected, every time.</strong> I don't cut corners on code to shave a quote.</li>
          <li><strong>Clean work.</strong> Conduit run straight, panel labeled, garage left the way I found it.</li>
        </ul>
      </div>
    </section>

    <section class="proof-placeholder" aria-label="Recent EV charger installs">
      <div class="container">
        <p class="proof-placeholder__label">Recent EV installs: photos coming soon</p>
      </div>
    </section>

    <section class="faq-section" id="faq" aria-labelledby="faq-title">
      <div class="container">
        <div class="faq-inner">
          <aside class="faq-sidebar">
            <span class="eyebrow">Questions</span>
            <h2 id="faq-title" class="faq-sidebar__title">EV charger FAQ</h2>
            <p>Have something else? Call and ask.</p>
            <a href="tel:+18052860477" class="btn btn--outline-dark">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              (805) 286-0477
            </a>
          </aside>
          <div class="faq-list">
            <details class="faq-item" open>
              <summary class="faq-item__btn"><span>Do you install Tesla Wall Connectors?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Yes. I install Tesla Wall Connectors along with the electrical work behind them, the dedicated circuit, breaker, conduit, and panel connection. I also install chargers for Rivian, Ford, and every other EV. If you've already bought your unit, I'll install it. If not, I'll help you pick the right one.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Do I need a 200-amp panel for an EV charger?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Not always. Plenty of homes can support EV charging without a panel upgrade. I do a load assessment first to confirm your home's actual capacity rather than assuming either way.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Should I install a plug-in charger or a hardwired one?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Both work. Hardwired chargers like the Tesla Wall Connector generally allow higher charging speeds and make for a cleaner permanent install. A NEMA 14-50 outlet can make sense for some setups, especially if you want flexibility. I'll walk you through which fits your situation.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>How long does an EV charger installation take?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Most standard installs are done in a few hours to most of a day, depending on the run from your panel and whether any panel work is needed. If a panel upgrade is required first, that adds time and I'll lay it out in the quote.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>Do I need a permit to install an EV charger?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>Most residential EV charger installs in SLO County need an electrical permit and inspection. I handle the permit, inspection, and utility coordination so it's code-compliant and signed off.</p></div>
            </details>
            <details class="faq-item">
              <summary class="faq-item__btn"><span>What areas do you cover for EV charger installation?</span><span class="faq-icon" aria-hidden="true"></span></summary>
              <div class="faq-item__body"><p>San Luis Obispo, Atascadero, Paso Robles, and the surrounding SLO County area. If you're not sure I reach you, call and ask.</p></div>
            </details>
          </div>
        </div>
      </div>
    </section>

    <section class="page-cta" id="contact" aria-labelledby="cta-title">
      <div class="container">
        <div class="page-cta__inner">
          <div>
            <span class="eyebrow eyebrow--light">Ready to charge at home?</span>
            <h2 id="cta-title" class="page-cta__title">Free estimates.<br/><em>Owner-operated.</em></h2>
            <p class="page-cta__lead">Free estimates. Licensed, insured, permitted. Owner-operated by Adam.</p>
            <div class="page-cta__btns">
              <a class="btn btn--primary btn--lg" href="tel:+18052860477">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
                Call (805) 286-0477
              </a>
              <a class="btn btn--outline-light btn--lg" href="mailto:adam@keifelectric.com?subject=EV%20charger%20quote%20request">Email a quote request</a>
            </div>
          </div>
          <div class="page-cta__card">
            <p class="page-cta__card-eyebrow">Free estimate</p>
            <a href="tel:+18052860477" class="page-cta__phone">(805) 286-0477</a>
            <div class="page-cta__trust">
              <span>California C-10 licensed</span>
              <span>Liability insured</span>
              <span>Mon–Fri, 9am–5pm</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <noscript>
    <style>
      .content-section .container--prose,
      .why-section .container--prose,
      .proof-placeholder .container,
      .faq-inner,
      .page-cta__inner { opacity: 1 !important; transform: none !important; }
    </style>
  </noscript>

  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--gutter);
    padding-right: var(--gutter);
  }

  .container--prose {
    max-width: 760px;
  }

  /* breadcrumb */
  .breadcrumb {
    background: var(--ke-bone);
    border-bottom: 1px solid var(--border-1);
    padding: 12px 0;
  }

  .breadcrumb .container {
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: 13px;
    color: var(--fg-2);
  }

  .breadcrumb a {
    color: var(--ke-orange);
    font-weight: 500;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  /* hero */
  .svc-hero {
    position: relative;
    background: var(--ke-bone);
    overflow: hidden;
    padding: 72px 0 88px;
  }

  .svc-hero::before {
    content: '';
    position: absolute;
    top: -25%;
    right: -12%;
    width: 62%;
    height: 130%;
    background: radial-gradient(closest-side, rgba(243, 152, 31, 0.12), transparent 72%);
    pointer-events: none;
  }

  .svc-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 0.85fr;
    gap: 56px;
    align-items: center;
  }

  .svc-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ke-clay);
    margin-bottom: 18px;
  }

  .svc-hero__spark { width: 15px; height: 15px; color: var(--ke-orange); }

  .svc-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-variation-settings: "YEAR" 2050;
    font-size: clamp(46px, 6.4vw, 92px);
    line-height: 0.9;
    letter-spacing: -0.005em;
    color: var(--ke-ink);
    margin: 0;
  }

  .svc-hero__line { display: block; }
  .svc-hero__line--accent { color: var(--ke-orange); }

  .svc-hero__dot {
    display: inline-block;
    width: 0.16em;
    height: 0.16em;
    background: var(--ke-orange);
    border-radius: 2px;
    margin-left: 0.05em;
    vertical-align: baseline;
  }

  .svc-hero__place {
    display: block;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(15px, 1.6vw, 19px);
    letter-spacing: 0;
    color: var(--fg-2);
    margin-top: 16px;
  }

  .svc-hero__sub {
    font-size: 18px;
    line-height: 1.55;
    color: var(--ke-ink);
    max-width: 46ch;
    margin: 26px 0 26px;
    font-weight: 500;
  }

  .svc-hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .svc-hero__trust {
    margin-top: 26px;
    font-size: 13px;
    font-weight: 600;
    color: var(--fg-2);
    letter-spacing: 0.01em;
  }

  .svc-hero__media {
    position: relative;
    justify-self: end;
    width: 100%;
    max-width: 440px;
  }

  .svc-hero__img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-4);
    box-shadow: var(--shadow-3);
    border: 1px solid var(--border-1);
  }

  .svc-hero__chip {
    position: absolute;
    left: -16px;
    bottom: 28px;
    background: var(--ke-ink);
    color: var(--ke-bone);
    padding: 12px 16px;
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-3);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .svc-hero__chip-k {
    font-weight: 800;
    font-size: 15px;
    color: var(--ke-amber);
    letter-spacing: 0.02em;
  }

  .svc-hero__chip-l {
    font-size: 12px;
    color: rgba(246, 241, 232, 0.8);
  }

  .btn--outline {
    background: transparent;
    color: var(--ke-ink);
    border-color: var(--ke-ink);
  }

  .btn--outline:hover { background: var(--ke-ink); color: var(--ke-bone); }

  /* hero entrance + scroll reveal */
  @media (prefers-reduced-motion: no-preference) {
    .svc-hero__eyebrow,
    .svc-hero__line,
    .svc-hero__place,
    .svc-hero__sub,
    .svc-hero__ctas,
    .svc-hero__trust,
    .svc-hero__media {
      opacity: 0;
      animation: heroIn 0.8s var(--ease-emph) forwards;
    }
    .svc-hero__eyebrow { animation-delay: 0.05s; }
    .svc-hero__line:nth-child(1) { animation-delay: 0.13s; }
    .svc-hero__line:nth-child(2) { animation-delay: 0.21s; }
    .svc-hero__place { animation-delay: 0.29s; }
    .svc-hero__sub { animation-delay: 0.37s; }
    .svc-hero__ctas { animation-delay: 0.45s; }
    .svc-hero__trust { animation-delay: 0.53s; }
    .svc-hero__media { animation-delay: 0.22s; animation-duration: 1s; }

    .content-section .container--prose,
    .why-section .container--prose,
    .proof-placeholder .container,
    .faq-inner,
    .page-cta__inner {
      opacity: 0;
